# ──────────────────────────────────────────────────────────────────────────────
# Cologic Shop Floor Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Camera ──────────────────────────────────────────────
# RTSP URL for the primary camera. Leave empty to start without a camera —
# you can add cameras via the dashboard Camera Setup wizard.
# Example: rtsp://admin:password@192.168.1.100:554/Streaming/Channels/101
RTSP_URL=

# ── Security ───────────────────────────────────────────
# Fernet key for encrypting RTSP credentials stored in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Random string for session/token signing
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Ingest API key — Edge_Agent authenticates to the Cloud_Server /api/ingest/*
# endpoints with this key (sent as X-Ingest-Key or Authorization: Bearer).
# Separate from SECRET_KEY / staff cookie login.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_API_KEY=

# ── Edge_Agent Local_Camera_Config ─────────────────────
# Path to the git-excluded JSON file mapping cloud machine_id -> local RTSP
# connection (rtsp_url / rtsp_url_encrypted, optional username/password).
# RTSP URLs and camera credentials live ONLY on the on-site Edge_Agent and are
# never sent to the cloud. See camera_config.example.json for the format.
CAMERA_CONFIG_PATH=camera_config.json

# ── Sync_Client (Edge_Agent → Cloud_Server) ────────────
# Base URL of the Cloud_Server Ingest_API. MUST be https:// — the Sync_Client
# refuses any other scheme. Example: https://tracker.example.com
CLOUD_SERVER_BASE_URL=
# Per-attempt transmission timeout in seconds (default 10).
SYNC_TRANSMISSION_TIMEOUT_SECONDS=10
# Consecutive failed attempts before the cloud is deemed unreachable (default 3).
SYNC_UNREACHABLE_FAILURE_THRESHOLD=3
# Single-delivery confirmation deadline in seconds (default 30).
SYNC_ACK_TIMEOUT_SECONDS=30
# Machine_Metadata poll interval in seconds, range 10-600 (default 60).
METADATA_POLL_INTERVAL_SECONDS=60

# ── AI Integration (optional) ──────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...

# ── Object Store (Google Cloud Storage) ────────────────
# Cloud_Server bucket for alert Event_Images. Leave empty to use the
# in-memory Object_Store fallback (development / tests only).
GCS_BUCKET=
# Path to a GCP service-account JSON key. Leave empty to use Application
# Default Credentials (ADC).
GOOGLE_APPLICATION_CREDENTIALS=

# ── Server ─────────────────────────────────────────────
# API port (default 8000)
API_PORT=8000

# Machine identification (default M-01)
MACHINE_ID=M-01

# ── Database ───────────────────────────────────────────
# Path to the SQLite database file
# In Docker: /app/data/tracker.db (volume-mounted)
# Local dev: tracker.db (project root)
DB_PATH=tracker.db
