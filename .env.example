# ──────────────────────────────────────────────────────────────────────────────
# Cologic Shop Floor Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Camera ──────────────────────────────────────────────
# RTSP URL for the primary camera. Leave empty to start without a camera —
# you can add cameras via the dashboard Camera Setup wizard.
# Example: rtsp://admin:password@192.168.1.100:554/Streaming/Channels/101
RTSP_URL=

# ── Security ───────────────────────────────────────────
# Fernet key for encrypting RTSP credentials stored in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Random string for session/token signing
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ── AI Integration (optional) ──────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...

# ── Server ─────────────────────────────────────────────
# API port (default 8000)
API_PORT=8000

# Machine identification (default M-01)
MACHINE_ID=M-01

# ── Database ───────────────────────────────────────────
# Path to the SQLite database file
# In Docker: /app/data/tracker.db (volume-mounted)
# Local dev: tracker.db (project root)
DB_PATH=tracker.db
